# SSH + code-server 全功能版本
# 镜像名: go_ts_vibe_codespace:all

FROM ubuntu:24.04

# 环境变量：语言、Go 版本与路径、国内代理
ENV LANG=C.UTF-8 \
    LANGUAGE=C.UTF-8 \
    GOLANG_VERSION=1.23.6 \
    GOPATH=/root/go \
    PATH=$PATH:/usr/local/go/bin:/root/go/bin:/root/.local/bin \
    GOPROXY=https://goproxy.cn,direct

# 层1: 系统包 — 基础工具、SSH 服务端+客户端、Node.js 20.x、Python3、pip 镜像源（极少变动）
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        git wget unzip curl ca-certificates openssh-server openssh-client \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends \
        nodejs python3 python3-pip python3-venv \
    && pip3 config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple \
    && apt-get autoremove -y \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 层2: Go 运行时（仅版本号变动时重建）
RUN wget -q https://go.dev/dl/go${GOLANG_VERSION}.linux-amd64.tar.gz \
    && tar -C /usr/local -xzf go${GOLANG_VERSION}.linux-amd64.tar.gz \
    && rm -f go${GOLANG_VERSION}.linux-amd64.tar.gz

# 层3: 全局 npm 包 — TypeScript（使用国内镜像源）
RUN npm config set registry https://registry.npmmirror.com \
    && npm install -g typescript ts-node \
    && npm cache clean --force

# 层4: Go 开发工具 — 语言服务器、调试器、静态分析（同层清缓存）
RUN go install -v golang.org/x/tools/gopls@latest \
    && go install -v github.com/go-delve/delve/cmd/dlv@latest \
    && go install -v honnef.co/go/tools/cmd/staticcheck@latest \
    && go clean -modcache \
    && go clean -cache

# 层5a: 安装 code-server 本体（少变动，缓存友好）
RUN curl -fsSL https://raw.githubusercontent.com/coder/code-server/main/install.sh | sh \
    && rm -rf /tmp/*

# 层5b: VS Code 扩展（增删扩展只重建此层，不必重装 code-server）
RUN code-server --install-extension MS-CEINTL.vscode-language-pack-zh-hans \
    && code-server --install-extension GitHub.github-vscode-theme \
    && code-server --install-extension DavidAnson.vscode-markdownlint \
    && code-server --install-extension golang.go \
    && code-server --install-extension streetsidesoftware.code-spell-checker \
    && code-server --install-extension ms-python.python \
    && code-server --install-extension g2developer.browser-in-vscode \
    && code-server --install-extension FittenTech.Fitten-Code \
    && code-server --install-extension saltcoreyan.json-format-sortcore \
    && code-server --install-extension redhat.vscode-yaml \
    && code-server --install-extension RooVeterinaryInc.roo-cline \
    && code-server --install-extension Anthropic.claude-code \
    && rm -rf /tmp/* /root/.cache

# 层6: 配置 SSH 服务端：创建运行目录，允许 root 登录
RUN mkdir -p /run/sshd \
    && sed -i 's/^#*PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config \
    && sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config

# 层7: AI 辅助工具及其他工具（变动频繁）
RUN npm install -g @anthropic-ai/claude-code@2.1.71 @cometix/ccline \
    && npm cache clean --force \
    && CC_SWITCH_FORCE=1 curl -fsSL https://github.com/SaladDay/cc-switch-cli/releases/latest/download/install.sh | bash

# 运行时配置（docker run -e 传入）
# ROOT_PASSWORD     — SSH root 密码，默认 root123
# CS_PASSWORD       — 设置后启用 code-server 密码认证，不设则免密
# GIT_USER_NAME     — git 用户名
# GIT_USER_EMAIL    — git 邮箱
# SSH_PRIVATE_KEY   — SSH 私钥内容（用于 git 操作）
# SSH_PUBLIC_KEY    — SSH 公钥内容
# 层8: 备份 /root 到卷覆盖不到的位置（避免遮盖镜像原始 /root）
RUN mkdir /root-defaults && cp -a /root /root-defaults

COPY entrypoint-all.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

WORKDIR /workspace
EXPOSE 8080 22
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
