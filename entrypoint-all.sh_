#!/bin/bash
set -e

# --- 合并镜像默认文件到持久化卷 ---
# -a 保留权限，-n 不覆盖已有文件（保留用户的自定义配置）
cp -an /root-defaults/root/. /root/ 2>/dev/null || true

# --- Git 配置 ---
if [ -n "$GIT_USER_NAME" ]; then
    git config --global user.name "$GIT_USER_NAME"
fi
if [ -n "$GIT_USER_EMAIL" ]; then
    git config --global user.email "$GIT_USER_EMAIL"
fi

# --- SSH 密钥配置（客户端，用于 git 操作）---
if [ -n "$SSH_PRIVATE_KEY" ]; then
    mkdir -p ~/.ssh && chmod 700 ~/.ssh
    echo "$SSH_PRIVATE_KEY" > ~/.ssh/id_rsa
    chmod 600 ~/.ssh/id_rsa
    if [ -n "$SSH_PUBLIC_KEY" ]; then
        echo "$SSH_PUBLIC_KEY" > ~/.ssh/id_rsa.pub
        chmod 644 ~/.ssh/id_rsa.pub
    fi
    # 自动信任常见 Git 托管平台
    ssh-keyscan -t rsa github.com gitlab.com gitee.com >> ~/.ssh/known_hosts 2>/dev/null
    chmod 644 ~/.ssh/known_hosts
fi

# --- SSH 服务端密码 ---
echo "root:${ROOT_PASSWORD:-root123}" | chpasswd

# --- code-server 密码认证 ---
AUTH_ARGS="--auth none"
if [ -n "$CS_PASSWORD" ]; then
    export PASSWORD="$CS_PASSWORD"
    AUTH_ARGS="--auth password"
fi

# --- ccline 提示 ---
echo '================================================'
echo ' ccline 已安装，可直接使用 ccline 命令。'
echo ' 如需集成到 Claude Code，请在 ~/.claude/settings.json 中配置：'
echo ''
echo '  {'
echo '    "statusLine": {'
echo '      "type": "command",'
echo '      "command": "ccline",'
echo '      "padding": 0'
echo '    }'
echo '  }'
echo '================================================'
echo ' IS_SANDBOX=1 claude --dangerously-skip-permissions 可以使Claude进入极限权限模式'
echo '================================================'

# 启动 SSH 服务（后台）
/usr/sbin/sshd

# 启动 code-server（前台）
exec code-server --bind-addr 0.0.0.0:8080 $AUTH_ARGS /workspace
